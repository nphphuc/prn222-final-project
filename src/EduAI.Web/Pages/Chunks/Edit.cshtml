@page "{id:int}"
@model EduAI.Web.Pages.Chunks.EditModel
@{ ViewData["Title"] = "Sửa đoạn văn"; }

<h2>Sửa đoạn #@Model.Input.ChunkIndex</h2>
<p class="text-muted">@Model.Input.SubjectName</p>

<form method="post" class="card p-3">
    <input type="hidden" asp-for="Input.Id" />
    <input type="hidden" asp-for="Input.SubjectId" />
    <input type="hidden" asp-for="Input.SubjectName" />
    <input type="hidden" asp-for="Input.ChapterId" />
    <input type="hidden" asp-for="Input.DocumentId" />
    <input type="hidden" asp-for="Input.ChunkIndex" />
    <div class="mb-3">
        <label asp-for="Input.Content" class="form-label"></label>
        <textarea asp-for="Input.Content" class="form-control" rows="12" required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-secondary">Hủy</a>
</form>
