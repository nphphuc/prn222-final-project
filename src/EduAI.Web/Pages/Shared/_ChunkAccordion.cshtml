@model (IReadOnlyList<EduAI.Model.DTOs.ChunkDto> Chunks, string AccordionId, bool ShowEmbedding)
@{
    var chunks = Model.Chunks;
    var accordionId = Model.AccordionId;
    var showEmbedding = Model.ShowEmbedding;
}

@if (chunks.Count == 0)
{
    <p class="text-muted mb-0 small">Không có đoạn văn nào.</p>
}
else
{
    <div class="accordion accordion-flush chunk-inline-accordion" id="@accordionId">
        @foreach (var chunk in chunks)
        {
            var collapseId = $"{accordionId}-item-{chunk.Id}";
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                        <span class="me-2">chunk @(chunk.ChunkIndex + 1)</span>
                        <span class="text-muted small">@chunk.ChapterName — @chunk.DocumentName</span>
                        @if (showEmbedding && chunk.HasEmbedding)
                        {
                            <span class="badge bg-success ms-2">Đã nhúng</span>
                        }
                    </button>
                </h2>
                <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#@accordionId">
                    <div class="accordion-body">
                        <pre class="chunk-content mb-0">@chunk.Content</pre>
                    </div>
                </div>
            </div>
        }
    </div>
}
