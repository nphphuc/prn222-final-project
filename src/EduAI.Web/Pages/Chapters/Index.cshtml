@page
@model EduAI.Web.Pages.Chapters.IndexModel
@{ ViewData["Title"] = "Chương"; }
<h2>Chương — @Model.ViewModel.SubjectName</h2>
<a asp-page="Create" asp-route-subjectId="@Model.ViewModel.SubjectId" class="btn btn-primary mb-3">Tạo chương</a>
<table class="table table-hover">
    <thead><tr><th>Thứ tự</th><th>Tên</th><th>Số tài liệu</th><th></th></tr></thead>
    <tbody>
    @foreach (var c in Model.ViewModel.Chapters)
    {
        <tr>
            <td>@c.OrderNumber</td>
            <td>@c.Name</td>
            <td>@c.DocumentCount</td>
            <td>
                <a asp-page="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                <a asp-page="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
            </td>
        </tr>
    }
    </tbody>
</table>
<a asp-page="/Subjects/Index" class="btn btn-secondary">Quay lại môn học</a>
