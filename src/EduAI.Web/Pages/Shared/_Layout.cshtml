@using Microsoft.AspNetCore.Identity
@using EduAI.Model.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";

    bool IsNavActive(params string[] prefixes)
    {
        foreach (var prefix in prefixes)
        {
            if (prefix.EndsWith('/'))
            {
                if (currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
                    return true;
            }
            else if (currentPage.Equals(prefix, StringComparison.OrdinalIgnoreCase)
                || currentPage.StartsWith(prefix + "/", StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }
        return false;
    }

    string NavClass(params string[] prefixes) =>
        IsNavActive(prefixes) ? "nav-link active" : "nav-link";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduAI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body" data-realtime-entities="@(ViewData["RealtimeEntities"] ?? "")" data-realtime-session-id="@(ViewData["RealtimeSessionId"] ?? "")">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light app-navbar">
            <div class="app-navbar-shell">
                <a class="navbar-brand app-navbar-brand" asp-page="/Index"><span class="app-navbar-brand-leading">E</span><span class="app-navbar-brand-tail">duAI</span></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse app-navbar-menu" id="navbarNav">
                    <div class="app-navbar-center">
                        <ul class="navbar-nav app-navbar-links">
                            @if (SignInManager.IsSignedIn(User))
                            {
                                @if (User.IsInRole(Roles.Admin))
                                {
                                    <li class="nav-item"><a class="@NavClass("/Users")" asp-page="/Users/Index">Người dùng</a></li>
                                    <li class="nav-item"><a class="@NavClass("/Subjects")" asp-page="/Subjects/Index">Môn học</a></li>
                                    <li class="nav-item"><a class="@NavClass("/Chunks")" asp-page="/Chunks/Index">Đoạn văn</a></li>
                                    <li class="nav-item"><a class="@NavClass("/AuditLogs")" asp-page="/AuditLogs/Index">Nhật ký</a></li>
                                    <li class="nav-item"><a class="@NavClass("/ChatSessions", "/ChatMessages")" asp-page="/ChatSessions/Index">Chat</a></li>
                                }
                                @if (User.IsInRole(Roles.Teacher))
                                {
                                    <li class="nav-item"><a class="@NavClass("/Subjects")" asp-page="/Subjects/Index">Môn học</a></li>
                                    <li class="nav-item"><a class="@NavClass("/Documents")" asp-page="/Documents/Create">Tải lên</a></li>
                                }
                                @if (User.IsInRole(Roles.Student))
                                {
                                    <li class="nav-item"><a class="@NavClass("/Chat/")" asp-page="/Chat/Index">Chatbot</a></li>
                                    <li class="nav-item"><a class="@NavClass("/Subjects")" asp-page="/Subjects/Index">Môn học</a></li>
                                }
                                <li class="nav-item"><a class="@NavClass("/Account/Profile")" asp-page="/Account/Profile">Tài khoản</a></li>
                                <li class="nav-item"><span class="nav-link navbar-text py-lg-2">@User.Identity?.Name</span></li>
                                <li class="nav-item">
                                    <form method="post" asp-page="/Account/Logout" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary ms-lg-1">Đăng xuất</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="@NavClass("/Account/Login")" asp-page="/Account/Login">Đăng nhập</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container app-main">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <footer class="app-footer">
        <div class="container">EduAI &mdash; Chatbot RAG &amp; Quản lý tài liệu</div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @if (SignInManager.IsSignedIn(User))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous"></script>
        <script src="~/js/user-realtime.js" asp-append-version="true"></script>
        <script src="~/js/app-realtime.js" asp-append-version="true"></script>
        <script>
            initUserRealtime({
                hubUrl: '@Url.Content("~/hubs/user")',
                logoutUrl: '@Url.Page("/Account/Logout", pageHandler: "Force", values: new { locked = 1 })'
            });
            initAppRealtime({
                hubUrl: '@Url.Content("~/hubs/notifications")',
                entities: document.body.dataset.realtimeEntities || '',
                sessionId: document.body.dataset.realtimeSessionId || ''
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
