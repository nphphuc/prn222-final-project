@page
@model EduAI.Web.Pages.Subjects.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Môn học";
    var role = User.IsInRole(Roles.Admin) ? Roles.Admin
        : User.IsInRole(Roles.Teacher) ? Roles.Teacher
        : Roles.Student;
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Môn học</h1>
        @if (User.IsInRole(Roles.Admin))
        {
            <p class="page-subtitle">Mỗi môn một giáo viên; một giáo viên có thể dạy nhiều môn.</p>
        }
    </div>
    @if (User.IsInRole(Roles.Admin))
    {
        <a asp-page="Create" class="btn btn-primary">+ Tạo môn</a>
    }
</div>

<div id="subject-realtime-toast" class="alert alert-info d-none mb-3" role="alert"></div>
@if (TempData["AssignTeacherError"] is string assignError)
{
    <div class="alert alert-danger">@assignError</div>
}
@if (TempData["AssignTeacherSuccess"] is string assignSuccess)
{
    <div class="alert alert-success">@assignSuccess</div>
}

<div id="subjects-empty" class="alert alert-secondary @(Model.ViewModel.Subjects.Count > 0 ? "d-none" : "")">Chưa có môn học nào.</div>
<div id="subjects-filter-empty" class="alert alert-secondary d-none">Không có môn học nào phù hợp bộ lọc.</div>

@if (User.IsInRole(Roles.Admin) && Model.ViewModel.Subjects.Count > 0)
{
    <ul class="nav nav-pills mb-3 subject-status-filter" id="subjectStatusFilter">
        <li class="nav-item">
            <button type="button" class="nav-link active" data-filter="all">Tất cả</button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link" data-filter="active">Đang hiển thị</button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link" data-filter="hidden">Đã ẩn</button>
        </li>
    </ul>
}

<div id="subjects-panel" class="panel-card @(Model.ViewModel.Subjects.Count == 0 ? "d-none" : "")">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Tên môn</th>
                    <th>Giáo viên</th>
                    <th>Mô tả</th>
                    <th>Tài liệu</th>
                    @if (User.IsInRole(Roles.Admin))
                    {
                        <th>Trạng thái</th>
                    }
                    <th></th>
                </tr>
            </thead>
            <tbody id="subjects-tbody">
            @foreach (var s in Model.ViewModel.Subjects)
            {
                <tr data-subject-id="@s.Id" data-teacher-id="@(s.TeacherId ?? "")" data-has-materials="@s.HasMaterials.ToString().ToLower()" data-is-active="@s.IsActive.ToString().ToLower()" class="@(User.IsInRole(Roles.Admin) && !s.IsActive ? "subject-row-inactive" : "")">
                    <td>
                        <strong>@s.Name</strong>
                    </td>
                    <td>
                        @if (User.IsInRole(Roles.Admin))
                        {
                            @if (!string.IsNullOrEmpty(s.TeacherName))
                            {
                                <span class="badge badge-teacher-assigned">@s.TeacherName</span>
                                <button type="button"
                                        class="badge badge-assign-teacher border-0 js-assign-teacher ms-1"
                                        data-subject-id="@s.Id"
                                        data-subject-name="@s.Name"
                                        data-teacher-id="@(s.TeacherId ?? "")">
                                    Đổi
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="badge badge-assign-teacher border-0 js-assign-teacher"
                                        data-subject-id="@s.Id"
                                        data-subject-name="@s.Name"
                                        data-teacher-id="">
                                    Gán giáo viên
                                </button>
                            }
                        }
                        else
                        {
                            @(s.TeacherName ?? "—")
                        }
                    </td>
                    <td class="text-muted">@(string.IsNullOrWhiteSpace(s.Description) ? "—" : s.Description)</td>
                    <td>
                        @if (s.DocumentCount <= 0)
                        {
                            <span class="text-muted">Chưa có tài liệu</span>
                        }
                        else
                        {
                            <a asp-page="Details" asp-route-id="@s.Id" class="badge badge-doc badge-doc-link text-decoration-none">@s.DocumentCount tài liệu</a>
                        }
                    </td>
                    @if (User.IsInRole(Roles.Admin))
                    {
                        <td>
                            @if (s.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Hiển thị</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">Đã ẩn</span>
                            }
                        </td>
                    }
                    <td class="text-nowrap">
                        <a asp-page="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                        @if (User.IsInRole(Roles.Admin))
                        {
                            <a asp-page="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                            @if (s.IsActive)
                            {
                                <form method="post" asp-page-handler="HideSubject" class="d-inline">
                                    <input type="hidden" name="subjectId" value="@s.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning"
                                            onclick="return confirm('Ẩn môn này? Giáo viên và sinh viên sẽ không còn thấy môn.');">
                                        Ẩn môn
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="RestoreSubject" class="d-inline">
                                    <input type="hidden" name="subjectId" value="@s.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Khôi phục</button>
                                </form>
                            }
                        }
                        @if (User.IsInRole(Roles.Teacher) && s.TeacherId == userId)
                        {
                            <a asp-page="/Documents/Create" asp-route-subjectId="@s.Id" class="btn btn-sm btn-primary">Tải lên</a>
                        }
                        @if (User.IsInRole(Roles.Student))
                        {
                            @if (s.DocumentCount > 0)
                            {
                                <a asp-page="/Study/Materials" asp-route-subjectId="@s.Id" class="btn btn-sm btn-outline-success">Tải về</a>
                            }
                            @if (s.HasMaterials)
                            {
                                <a asp-page="/Chat/Create" asp-route-subjectId="@s.Id" class="btn btn-sm btn-primary">Chat</a>
                            }
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (User.IsInRole(Roles.Admin))
{
    <div class="modal fade" id="assignTeacherModal" tabindex="-1" aria-labelledby="assignTeacherModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form method="post" asp-page-handler="AssignTeacher">
                    <div class="modal-header">
                        <h5 class="modal-title" id="assignTeacherModalLabel">Gán / Đổi giáo viên</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted mb-3">Môn: <strong id="assignTeacherSubjectName">—</strong></p>
                        <input type="hidden" name="subjectId" id="assignTeacherSubjectId" value="" />
                        <label for="assignTeacherSelect" class="form-label">Chọn giáo viên</label>
                        <select name="teacherId" id="assignTeacherSelect" class="form-select" asp-items="Model.TeacherOptions">
                            <option value="">-- Để trống (gỡ giáo viên) --</option>
                        </select>
                        <div class="form-text">Có thể đổi sang giáo viên khác hoặc để trống. Một giáo viên có thể dạy nhiều môn.</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary">Lưu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/subject-realtime.js" asp-append-version="true"></script>
    <script>
        initSubjectRealtime(@Html.Raw(JsonSerializer.Serialize(new {
            hubUrl = Url.Content("~/hubs/subjects"),
            role,
            userId,
            urls = new {
                details = Url.Page("/Subjects/Details"),
                edit = Url.Page("/Subjects/Edit"),
                upload = User.IsInRole(Roles.Teacher) ? Url.Page("/Documents/Create") : null,
                materials = Url.Page("/Study/Materials"),
                chatCreate = Url.Page("/Chat/Create"),
                index = Url.Page("/Subjects/Index"),
                documentDetails = Url.Page("/Documents/Details")
            }
        })));
        (function () {
            var modalEl = document.getElementById('assignTeacherModal');
            if (!modalEl || !window.bootstrap) return;
            var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            var formEl = modalEl.querySelector('form');
            var subjectIdInput = document.getElementById('assignTeacherSubjectId');
            var subjectNameEl = document.getElementById('assignTeacherSubjectName');
            var teacherSelect = document.getElementById('assignTeacherSelect');
            var currentTeacherId = '';
            document.addEventListener('click', function (e) {
                var btn = e.target.closest('.js-assign-teacher');
                if (!btn) return;
                subjectIdInput.value = btn.getAttribute('data-subject-id') || '';
                subjectNameEl.textContent = btn.getAttribute('data-subject-name') || '—';
                currentTeacherId = btn.getAttribute('data-teacher-id') || '';
                if (teacherSelect) teacherSelect.value = currentTeacherId;
                modal.show();
            });
            if (formEl) {
                formEl.addEventListener('submit', function (e) {
                    if (currentTeacherId && teacherSelect && teacherSelect.value !== currentTeacherId) {
                        if (!window.confirm('Bạn chắc chắn sẽ đổi giảng viên này không?')) {
                            e.preventDefault();
                        }
                    }
                });
            }
        })();
        (function () {
            var filterEl = document.getElementById('subjectStatusFilter');
            if (!filterEl) return;
            var tbody = document.getElementById('subjects-tbody');
            var rows = tbody ? Array.from(tbody.querySelectorAll('tr[data-is-active]')) : [];
            var emptyEl = document.getElementById('subjects-empty');
            var filterEmptyEl = document.getElementById('subjects-filter-empty');
            var panelEl = document.getElementById('subjects-panel');
            var totalRows = rows.length;

            function applyFilter(filter) {
                var visible = 0;
                rows.forEach(function (row) {
                    var isActive = row.getAttribute('data-is-active') === 'true';
                    var show = filter === 'all'
                        || (filter === 'active' && isActive)
                        || (filter === 'hidden' && !isActive);
                    row.classList.toggle('d-none', !show);
                    if (show) visible++;
                });
                filterEl.querySelectorAll('[data-filter]').forEach(function (btn) {
                    btn.classList.toggle('active', btn.getAttribute('data-filter') === filter);
                });
                if (emptyEl) emptyEl.classList.toggle('d-none', totalRows > 0);
                if (filterEmptyEl) filterEmptyEl.classList.toggle('d-none', visible > 0 || totalRows === 0);
                if (panelEl) panelEl.classList.toggle('d-none', visible === 0);
            }

            filterEl.addEventListener('click', function (e) {
                var btn = e.target.closest('[data-filter]');
                if (!btn) return;
                applyFilter(btn.getAttribute('data-filter'));
            });
        })();
    </script>
}
