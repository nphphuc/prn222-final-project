@page "{id:int}"
@model EduAI.Web.Pages.AuditLogs.DetailsModel
@{
    ViewData["Title"] = "Chi tiết nhật ký";
    var log = Model.ViewModel.Log!;
}

<h2>Chi tiết nhật ký</h2>

<dl class="row">
    <dt class="col-sm-3">Thời gian</dt><dd class="col-sm-9">@log.Timestamp.ToString("G")</dd>
    <dt class="col-sm-3">Người dùng</dt><dd class="col-sm-9">@(log.UserName ?? log.UserId ?? "Hệ thống")</dd>
    <dt class="col-sm-3">Hành động</dt><dd class="col-sm-9">@log.Action</dd>
    <dt class="col-sm-3">Địa chỉ IP</dt><dd class="col-sm-9">@(log.IpAddress ?? "-")</dd>
    <dt class="col-sm-3">Chi tiết</dt><dd class="col-sm-9">@(log.Details ?? "-")</dd>
</dl>

<div class="d-flex gap-2">
    <a asp-page="Index" class="btn btn-secondary">Quay lại</a>
</div>
