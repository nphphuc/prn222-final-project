@model EduAI.Model.DTOs.DocumentDto
@{
    var compact = ViewData["Compact"] as bool? ?? false;
}
@if (Model.IndexStatus == "Indexed")
{
    @if (compact)
    {
        <span class="text-muted small">đã index</span>
    }
    else
    {
        <span class="badge status-indexed">✓ đã tải nội dung thành công</span>
    }
}
else if (Model.IndexStatus == "Processing")
{
    @if (compact)
    {
        <span class="text-muted small">đang xử lý</span>
    }
    else
    {
        <span class="badge status-processing">Đang xử lý</span>
    }
}
else if (Model.IndexStatus == "Failed")
{
    @if (compact)
    {
        <span class="text-danger small" title="@Model.IndexError">lỗi xử lý</span>
    }
    else
    {
        <span class="badge bg-danger" title="@Model.IndexError">Lỗi xử lý</span>
        @if (!string.IsNullOrWhiteSpace(Model.IndexError))
        {
            <div class="small text-danger mt-1" style="max-width: 220px;">@Model.IndexError</div>
        }
    }
}
else
{
    @if (compact)
    {
        <span class="text-muted small">chờ xử lý</span>
    }
    else
    {
        <span class="badge status-pending">Chờ xử lý</span>
    }
}
