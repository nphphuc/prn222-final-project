@page
@model EduAI.Web.Pages.Account.ConfirmEmailModel
@{
    ViewData["Title"] = "Xác thực email";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác thực email - EduAI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">
    <div class="login-card">
        <div class="login-brand">EduAI</div>
        <h2 class="h5 mb-3">Xác thực email</h2>
        <div class="alert @(Model.Succeeded ? "alert-success" : "alert-warning") mb-3">
            @Model.Message
        </div>
        <a asp-page="/Account/Login" class="btn btn-primary w-100">Đến trang đăng nhập</a>
    </div>
</body>
</html>
