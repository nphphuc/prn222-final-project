@page
@model EduAI.Web.Pages.Account.ProfileModel
@{ ViewData["Title"] = "Tài khoản của tôi"; }

<div class="page-header mb-4">
    <div>
        <h1 class="page-title">Tài khoản của tôi</h1>
        <p class="page-subtitle">Vai trò: <strong>@(Model.Input.Role == Roles.Admin ? "Quản trị viên" : Model.Input.Role == Roles.Teacher ? "Giáo viên" : Model.Input.Role == Roles.Student ? "Sinh viên" : Model.Input.Role)</strong></p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="panel-card panel-card-body mb-3">
    <dl class="row mb-0">
        <dt class="col-sm-3">Họ tên</dt><dd class="col-sm-9">@Model.Input.FullName</dd>
        <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Input.Email</dd>
    </dl>
</div>

@if (!Model.Input.IsAdmin)
{
    <div class="d-flex flex-wrap gap-2 mb-3">
        <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#profile-edit-panel" aria-expanded="@(Model.ActiveSection == "profile" ? "true" : "false")">
            Sửa thông tin
        </button>
        <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#profile-password-panel" aria-expanded="@(Model.ActiveSection == "password" ? "true" : "false")">
            Đổi mật khẩu
        </button>
    </div>

    <div class="collapse @(Model.ActiveSection == "profile" ? "show" : "")" id="profile-edit-panel">
        <form method="post" asp-page-handler="SaveProfile" class="panel-card panel-card-body mb-3">
            <input type="hidden" asp-for="Input.Id" />
            <input type="hidden" asp-for="Input.Role" />
            <input type="hidden" asp-for="Input.IsAdmin" />
            <h5 class="mb-3">Sửa thông tin cá nhân</h5>
            <div class="mb-3">
                <label asp-for="Input.FullName" class="form-label">Họ tên</label>
                <input asp-for="Input.FullName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email đăng nhập</label>
                <input asp-for="Input.Email" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary">Lưu thông tin</button>
        </form>
    </div>

    <div class="collapse @(Model.ActiveSection == "password" ? "show" : "")" id="profile-password-panel">
        <form method="post" asp-page-handler="ChangePassword" class="panel-card panel-card-body">
            <input type="hidden" asp-for="Input.Id" />
            <input type="hidden" asp-for="Input.FullName" />
            <input type="hidden" asp-for="Input.Email" />
            <input type="hidden" asp-for="Input.Role" />
            <input type="hidden" asp-for="Input.IsAdmin" />
            <h5 class="mb-3">Đổi mật khẩu</h5>
            <div class="mb-3">
                <label asp-for="Input.CurrentPassword" class="form-label">Mật khẩu hiện tại</label>
                <div class="input-group">
                    <input asp-for="Input.CurrentPassword" class="form-control js-password" type="password" autocomplete="current-password" />
                    <button class="btn btn-outline-secondary js-toggle-password" type="button">Hiện</button>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Input.NewPassword" class="form-label">Mật khẩu mới</label>
                <div class="input-group">
                    <input asp-for="Input.NewPassword" class="form-control js-password" type="password" autocomplete="new-password" />
                    <button class="btn btn-outline-secondary js-toggle-password" type="button">Hiện</button>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Input.ConfirmNewPassword" class="form-label">Xác nhận mật khẩu mới</label>
                <div class="input-group">
                    <input asp-for="Input.ConfirmNewPassword" class="form-control js-password" type="password" autocomplete="new-password" />
                    <button class="btn btn-outline-secondary js-toggle-password" type="button">Hiện</button>
                </div>
            </div>
            <button type="submit" class="btn btn-outline-primary">Đổi mật khẩu</button>
        </form>
    </div>
}

@section Scripts
{
    <script>
        (() => {
            document.querySelectorAll('.js-toggle-password').forEach(btn => {
                btn.addEventListener('click', () => {
                    const group = btn.closest('.input-group');
                    const input = group?.querySelector('input.js-password');
                    if (!input) return;
                    const isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    btn.textContent = isPassword ? 'Ẩn' : 'Hiện';
                });
            });
        })();
    </script>
}
