@page
@model EduAI.Web.Pages.AuditLogs.IndexModel
@{ ViewData["Title"] = "Nhật ký hệ thống"; ViewData["RealtimeEntities"] = "AuditLog"; }

<h2>Nhật ký hệ thống</h2>
<p class="text-muted">Nhật ký hệ thống chỉ được xem, không thể chỉnh sửa hoặc xóa.</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-2">
        <label asp-for="Filter.Action" class="form-label"></label>
        <input asp-for="Filter.Action" class="form-control" list="auditActions" />
        <datalist id="auditActions">
            @foreach (var action in Model.KnownActions)
            {
                <option value="@action"></option>
            }
        </datalist>
    </div>
    <div class="col-md-2">
        <label asp-for="Filter.UserId" class="form-label"></label>
        <input asp-for="Filter.UserId" class="form-control" placeholder="Mã người dùng" />
    </div>
    <div class="col-md-2">
        <label asp-for="Filter.IpAddress" class="form-label"></label>
        <input asp-for="Filter.IpAddress" class="form-control" />
    </div>
    <div class="col-md-2">
        <label asp-for="Filter.From" class="form-label"></label>
        <input asp-for="Filter.From" type="date" class="form-control" />
    </div>
    <div class="col-md-2">
        <label asp-for="Filter.To" class="form-label"></label>
        <input asp-for="Filter.To" type="date" class="form-control" />
    </div>
    <div class="col-md-2">
        <label asp-for="Filter.DetailsContains" class="form-label"></label>
        <input asp-for="Filter.DetailsContains" class="form-control" />
    </div>
    <div class="col-md-2">
        <label asp-for="Filter.MaxResults" class="form-label"></label>
        <input asp-for="Filter.MaxResults" type="number" min="1" class="form-control" />
    </div>
    <div class="col-md-12">
        <button type="submit" class="btn btn-primary">Lọc</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Đặt lại</a>
    </div>
</form>

<p class="text-muted">@Model.ViewModel.Logs.Count kết quả</p>

@if (Model.ViewModel.Logs.Count == 0)
{
    <div class="alert alert-secondary">Không có nhật ký phù hợp bộ lọc hiện tại.</div>
}
else
{
    <table class="table table-sm table-hover">
        <thead><tr><th>Thời gian</th><th>Người dùng</th><th>Hành động</th><th>IP</th><th>Chi tiết</th><th></th></tr></thead>
        <tbody id="audit-live-body">
        @foreach (var log in Model.ViewModel.Logs)
        {
            <tr>
                <td>@log.Timestamp.ToString("g")</td>
                <td>@(log.UserName ?? log.UserId ?? "Hệ thống")</td>
                <td>@log.Action</td>
                <td>@log.IpAddress</td>
                <td>@(log.Details?.Length > 100 ? log.Details[..100] + "..." : log.Details)</td>
                <td><a asp-page="Details" asp-route-id="@log.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a></td>
            </tr>
        }
        </tbody>
    </table>
}
