@page "{id:int}"
@model EduAI.Web.Pages.Chat.DetailsModel
@{ ViewData["Title"] = Model.ViewModel.Title; }

<div class="chat-layout">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Model.ViewModel.Title</h1>
            <p class="page-subtitle">Môn: <strong>@Model.ViewModel.SubjectName</strong></p>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="Edit" asp-route-id="@Model.ViewModel.SessionId" class="btn btn-sm btn-outline-secondary">Cài đặt</a>
            <a asp-page="Index" class="btn btn-sm btn-outline-secondary">Tất cả phiên</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
    }

    <div id="chat-box" class="chat-box mb-3">
        @if (Model.ViewModel.Messages.Count == 0)
        {
            <div class="chat-empty text-muted text-center py-5">Hãy đặt câu hỏi đầu tiên về tài liệu môn học.</div>
        }
        @foreach (var m in Model.ViewModel.Messages)
        {
            var isUser = m.Role == "user";
            <div class="chat-message @(isUser ? "chat-user" : "chat-assistant")">
                <div class="chat-bubble">
                    <div class="chat-role">@(isUser ? "Bạn" : "EduAI")</div>
                    <div class="chat-text">@m.Content</div>
                    @if (!string.IsNullOrEmpty(m.Citations))
                    {
                        <div class="chat-citations">Nguồn: @m.Citations</div>
                    }
                </div>
            </div>
        }
        <div id="chat-box-end" aria-hidden="true"></div>
    </div>

    <form method="post" class="chat-input-bar" id="chat-form">
        <div class="input-group chat-input-group">
            <textarea class="form-control" asp-for="Question" id="chat-question" rows="2"
                      placeholder="Hỏi về @Model.ViewModel.SubjectName... (Enter gửi, Shift+Enter xuống dòng)"
                      autocomplete="off" required></textarea>
            <button type="submit" class="btn btn-primary" id="chat-send-btn">Gửi</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/chat-details.js" asp-append-version="true"></script>
}
