@page "{id}"
@model EduAI.Web.Pages.Users.EditModel
@{ ViewData["Title"] = "Quản lý người dùng"; }

<h2 class="page-title">Quản lý người dùng</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="panel-card panel-card-body mb-3">
    <dl class="row mb-0">
        <dt class="col-sm-3">Họ tên</dt><dd class="col-sm-9">@Model.Input.FullName</dd>
        <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Input.Email</dd>
        <dt class="col-sm-3">Vai trò</dt><dd class="col-sm-9">@Model.Input.Role</dd>
        <dt class="col-sm-3">Trạng thái</dt>
        <dd class="col-sm-9">
            @if (Model.Input.IsActive)
            {
                <span class="badge bg-success">Đang hoạt động</span>
            }
            else
            {
                <span class="badge bg-secondary">Đã khóa</span>
            }
        </dd>
    </dl>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#edit-profile-panel" aria-expanded="@(Model.ActiveSection == "profile" ? "true" : "false")">
        Sửa thông tin
    </button>
    <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#edit-password-panel" aria-expanded="@(Model.ActiveSection == "password" ? "true" : "false")">
        Đổi mật khẩu
    </button>
    @if (Model.Input.IsActive)
    {
        <form method="post" asp-page-handler="Deactivate" asp-route-id="@Model.Input.Id" class="d-inline">
            <button type="submit" class="btn btn-warning" onclick="return confirm('Khóa tài khoản? Người dùng sẽ bị đăng xuất ngay.');">Khóa tài khoản</button>
        </form>
    }
    else
    {
        <form method="post" asp-page-handler="Activate" asp-route-id="@Model.Input.Id" class="d-inline">
            <button type="submit" class="btn btn-success" onclick="return confirm('Mở khóa? Người dùng phải đăng nhập lại.');">Mở khóa</button>
        </form>
    }
    <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-secondary">Quay lại</a>
</div>

<div class="collapse @(Model.ActiveSection == "profile" ? "show" : "")" id="edit-profile-panel">
    <form method="post" asp-page-handler="SaveProfile" asp-route-id="@Model.Input.Id" class="panel-card panel-card-body mb-3">
        <h5 class="mb-3">Sửa thông tin</h5>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.FullName" class="form-label">Họ tên</label>
            <input asp-for="Input.FullName" class="form-control" required />
        </div>
        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label">Email đăng nhập</label>
            <input asp-for="Input.Email" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-primary">Lưu thông tin</button>
    </form>
</div>

<div class="collapse @(Model.ActiveSection == "password" ? "show" : "")" id="edit-password-panel">
    <form method="post" asp-page-handler="ResetPassword" asp-route-id="@Model.Input.Id" class="panel-card panel-card-body mb-3">
        <h5 class="mb-3">Đặt lại mật khẩu</h5>
        <div class="mb-3">
            <label asp-for="Input.NewPassword" class="form-label">Mật khẩu mới</label>
            <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.ConfirmNewPassword" class="form-label">Xác nhận mật khẩu</label>
            <input asp-for="Input.ConfirmNewPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmNewPassword" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-outline-primary">Cập nhật mật khẩu</button>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
