@page "{id:int}"

@model EduAI.Web.Pages.Subjects.EditModel

@{ ViewData["Title"] = "Sửa môn học"; }

<h2>Sửa môn học</h2>

<form method="post">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Input.Id" />

    <div class="mb-3">

        <label asp-for="Input.Name" class="form-label"></label>

        <input asp-for="Input.Name" class="form-control" />

    </div>

    <div class="mb-3">

        <label asp-for="Input.Description" class="form-label"></label>

        <textarea asp-for="Input.Description" class="form-control"></textarea>

    </div>

    <div class="mb-3">

        <label asp-for="Input.TeacherId" class="form-label">Giáo viên phụ trách</label>

        <select asp-for="Input.TeacherId" asp-items="Model.TeacherOptions" class="form-select" id="teacherSelect" data-current-teacher="@(Model.Input.TeacherId ?? "")">

            <option value="">-- Để trống (gỡ giáo viên) --</option>

        </select>

        <div class="form-text">Có thể đổi sang giáo viên khác hoặc để trống. Một giáo viên có thể phụ trách nhiều môn.</div>

    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>

    <a asp-page="Index" class="btn btn-secondary">Hủy</a>

</form>

@section Scripts {

    <script>

        (function () {

            var form = document.querySelector('form');

            var select = document.getElementById('teacherSelect');

            if (!form || !select) return;

            var current = select.getAttribute('data-current-teacher') || '';

            form.addEventListener('submit', function (e) {

                if (current && select.value !== current) {

                    if (!window.confirm('Bạn chắc chắn sẽ đổi giảng viên này không?')) {

                        e.preventDefault();

                    }

                }

            });

        })();

    </script>

}

