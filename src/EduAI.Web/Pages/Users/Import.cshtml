@page
@model EduAI.Web.Pages.Users.ImportModel
@{
    ViewData["Title"] = "Import tài khoản từ Excel";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Import tài khoản từ Excel</h1>
        <p class="page-subtitle">Tải lên file Excel (.xlsx) để tạo tài khoản hàng loạt.</p>
    </div>
    <a asp-page="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="panel-card">
            <div class="card-body p-4">
                <form method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Chọn file Excel</label>
                        <div class="upload-dropzone border-2 border-dashed rounded-3 p-5 text-center" id="dropzone" style="border: 2px dashed #adb5bd; cursor: pointer;">
                            <input type="file" name="UploadFile" id="file-input" class="d-none" accept=".xlsx,.xls" required />
                            <div class="upload-dropzone-content">
                                <div class="mb-2" style="font-size: 2.5rem; color: #6c757d;">&#128196;</div>
                                <p class="mb-1 fw-medium">Kéo &amp; thả file vào đây, hoặc click để chọn</p>
                                <p class="text-muted small mb-2">Hỗ trợ .xlsx, .xls</p>
                                <span class="btn btn-sm btn-outline-primary">Chọn file</span>
                                <p class="upload-file-name mt-2 mb-0 text-muted small" id="file-name">Chưa chọn file</p>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" id="submit-btn">
                            <span aria-hidden="true">&#8682;</span> Import tài khoản
                        </button>
                        <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="panel-card">
            <div class="card-body p-4">
                <h5 class="fw-semibold mb-3">&#128203; Hướng dẫn</h5>
                <p class="text-muted small mb-2">File Excel cần có cấu trúc như sau:</p>
                <div class="table-responsive small mb-3">
                    <table class="table table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Cột A</th>
                                <th>Cột B</th>
                                <th>Cột C</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>Full Name</strong></td>
                                <td><strong>Email</strong></td>
                                <td><strong>Role</strong></td>
                            </tr>
                            <tr>
                                <td>Nguyễn Văn A</td>
                                <td>vana@example.com</td>
                                <td>Student</td>
                            </tr>
                            <tr>
                                <td>Trần Thị B</td>
                                <td>thib@example.com</td>
                                <td>Teacher</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <ul class="text-muted small mb-0 ps-3">
                    <li>Hàng đầu tiên là tiêu đề (sẽ được bỏ qua).</li>
                    <li>Role chỉ chấp nhận <code>Teacher</code> hoặc <code>Student</code>.</li>
                    <li>Email phải là duy nhất trong hệ thống.</li>
                    <li>Mật khẩu tạm thời sẽ được tạo tự động và gửi qua email.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@if (Model.ImportResult != null)
{
    <div class="panel-card mt-4">
        <div class="card-body p-4">
            <h4 class="fw-semibold mb-3">Kết quả import</h4>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="border rounded-3 p-3 text-center">
                        <div class="fs-4 fw-bold">@Model.ImportResult.TotalRows</div>
                        <div class="text-muted small">Tổng số dòng</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded-3 p-3 text-center border-success">
                        <div class="fs-4 fw-bold text-success">@Model.ImportResult.SuccessCount</div>
                        <div class="text-muted small">Thành công</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded-3 p-3 text-center border-danger">
                        <div class="fs-4 fw-bold text-danger">@Model.ImportResult.FailCount</div>
                        <div class="text-muted small">Thất bại</div>
                    </div>
                </div>
            </div>

            @if (Model.ImportResult.Results.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead>
                            <tr>
                                <th>Dòng</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Vai trò</th>
                                <th>Kết quả</th>
                                <th>Mật khẩu tạm</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.ImportResult.Results)
                            {
                                <tr class="@(row.Success ? "" : "table-danger")">
                                    <td>@row.RowNumber</td>
                                    <td>@row.FullName</td>
                                    <td>@row.Email</td>
                                    <td>
                                        <span class="badge @(row.Role == Roles.Teacher ? "badge-doc" : "bg-info")">
                                            @(row.Role == Roles.Teacher ? "Giáo viên" : row.Role == Roles.Student ? "Sinh viên" : row.Role)
                                        </span>
                                    </td>
                                    <td>
                                        @if (row.Success)
                                        {
                                            <span class="badge bg-success">Thành công</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger" title="@row.ErrorMessage">Lỗi</span>
                                            <span class="text-danger small d-block">@row.ErrorMessage</span>
                                        }
                                    </td>
                                    <td>
                                        @if (row.Success && !string.IsNullOrEmpty(row.TemporaryPassword))
                                        {
                                            <code class="user-select-all">@row.TemporaryPassword</code>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        (function () {
            const dropzone = document.getElementById('dropzone');
            const fileInput = document.getElementById('file-input');
            const fileName = document.getElementById('file-name');
            const submitBtn = document.getElementById('submit-btn');

            dropzone?.addEventListener('click', function (e) {
                if (e.target.tagName !== 'INPUT') fileInput?.click();
            });

            fileInput?.addEventListener('change', function () {
                if (this.files?.[0]) {
                    const file = this.files[0];
                    const mb = (file.size / (1024 * 1024)).toFixed(2);
                    fileName.textContent = file.name + ' (' + mb + ' MB)';
                }
            });

            dropzone?.addEventListener('dragover', function (e) {
                e.preventDefault();
                dropzone.style.borderColor = '#0d6efd';
                dropzone.style.backgroundColor = '#f0f7ff';
            });

            dropzone?.addEventListener('dragleave', function () {
                dropzone.style.borderColor = '#adb5bd';
                dropzone.style.backgroundColor = '';
            });

            dropzone?.addEventListener('drop', function (e) {
                e.preventDefault();
                dropzone.style.borderColor = '#adb5bd';
                dropzone.style.backgroundColor = '';
                if (e.dataTransfer.files?.length && fileInput) {
                    fileInput.files = e.dataTransfer.files;
                    const file = e.dataTransfer.files[0];
                    const mb = (file.size / (1024 * 1024)).toFixed(2);
                    fileName.textContent = file.name + ' (' + mb + ' MB)';
                }
            });

            document.querySelector('form')?.addEventListener('submit', function () {
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span> Đang xử lý...';
                }
            });
        })();
    </script>
}
