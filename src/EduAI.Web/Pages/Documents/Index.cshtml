@page
@model EduAI.Web.Pages.Documents.IndexModel
@{ ViewData["Title"] = "Tài liệu"; ViewData["RealtimeEntities"] = "Document,Chunk,Embedding"; }

<div class="page-header">
    <div>
        <h1 class="page-title">@Model.ViewModel.SubjectName</h1>
    </div>
    <div class="d-flex gap-2">
        @if (Model.CanUpload)
        {
            <a asp-page="Create" asp-route-subjectId="@Model.ViewModel.SubjectId" class="btn btn-primary">+ Tải lên</a>
        }
        <a asp-page="/Subjects/Details" asp-route-id="@Model.ViewModel.SubjectId" class="btn btn-outline-secondary">← Môn học</a>
    </div>
</div>

@if (Model.ViewModel.Documents.Count == 0)
{
    <div class="alert alert-secondary">
        Chưa có tài liệu.
            @if (Model.CanUpload)
            {
                <a asp-page="Create" asp-route-subjectId="@Model.ViewModel.SubjectId" class="alert-link">Tải lên ngay</a>
            }
    </div>
}
else
{
    <div class="panel-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Tệp</th>
                        <th>Chương</th>
                        <th>Bài</th>
                        <th>Loại</th>
                        <th>Phân loại</th>
                        <th>Đoạn văn</th>
                        <th>Trạng thái</th>
                        <th>Tải lên bởi</th>
                        <th>Ngày</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var doc in Model.ViewModel.Documents)
                {
                    var isExpanded = Model.ExpandedDocumentId == doc.Id;
                    <tr>
                        <td><strong>@doc.FileName</strong></td>
                        <td>@doc.ChapterName</td>
                        <td>@doc.LessonName</td>
                        <td><span class="badge badge-doc">@doc.FileType</span></td>
                        <td class="text-muted">@doc.CategoryLabel</td>
                        <td>
                            @if (doc.ChunkCount > 0)
                            {
                                if (isExpanded)
                                {
                                    <a asp-page="Index" asp-route-subjectId="@Model.ViewModel.SubjectId" class="badge badge-chunk badge-chunk-link text-decoration-none">@doc.ChunkCount ▲</a>
                                }
                                else
                                {
                                    <a asp-page="Index" asp-route-subjectId="@Model.ViewModel.SubjectId" asp-route-showChunks="@doc.Id" class="badge badge-chunk badge-chunk-link text-decoration-none">@doc.ChunkCount ▼</a>
                                }
                            }
                            else
                            {
                                <span class="text-muted">0</span>
                            }
                        </td>
                        <td>
                            @if (doc.IndexStatus == "Indexed")
                            {
                                <span class="badge status-indexed">đã tải nội dung thành công</span>
                            }
                            else if (doc.IndexStatus == "Processing")
                            {
                                <span class="badge status-processing">Đang xử lý</span>
                            }
                            else if (doc.IndexStatus == "Failed")
                            {
                                <span class="badge bg-danger" title="@doc.IndexError">Lỗi xử lý</span>
                                @if (!string.IsNullOrWhiteSpace(doc.IndexError))
                                {
                                    <div class="small text-danger mt-1" style="max-width: 220px;">@doc.IndexError</div>
                                }
                            }
                            else
                            {
                                <span class="badge status-pending">Chờ xử lý</span>
                            }
                        </td>
                        <td class="text-muted">@doc.UploadedByName</td>
                        <td class="text-muted">@doc.CreatedAt.ToString("g")</td>
                        <td class="text-nowrap">
                            <a asp-page="/Study/Download" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-success">Tải</a>
                            <a asp-page="Details" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                            @if (Model.CanUpload)
                            {
                                <a asp-page="Edit" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                                @if (doc.IndexStatus == "Failed" || doc.IndexStatus == "Pending")
                                {
                                    <form method="post" asp-page-handler="Reindex" class="d-inline">
                                        <input type="hidden" name="documentId" value="@doc.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Xử lý lại</button>
                                    </form>
                                }
                            }
                        </td>
                    </tr>
                    @if (isExpanded)
                    {
                        <tr class="chunk-expand-row">
                            <td colspan="10">
                                <div class="chunk-inline-panel">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <strong>Đoạn văn — @doc.FileName (@Model.ExpandedChunks.Count)</strong>
                                        <a asp-page="Index" asp-route-subjectId="@Model.ViewModel.SubjectId" class="btn btn-sm btn-outline-secondary">Đóng</a>
                                    </div>
                                    @{
                                        var chunkAccordionId = "doc-chunks-" + doc.Id;
                                    }
                                    <partial name="_ChunkAccordion" model="(Model.ExpandedChunks, chunkAccordionId, Model.ShowEmbedding)" />
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
}
