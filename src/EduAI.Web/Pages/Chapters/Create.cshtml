@page
@model EduAI.Web.Pages.Chapters.CreateModel
@{ ViewData["Title"] = "Tạo chương"; }
<h2>Tạo chương — @Model.Input.SubjectName</h2>
<form method="post">
    <input type="hidden" asp-for="Input.SubjectId" />
    <input type="hidden" asp-for="Input.SubjectName" />
    <div class="mb-3">
        <label asp-for="Input.Name" class="form-label"></label>
        <input asp-for="Input.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Input.OrderNumber" class="form-label"></label>
        <input asp-for="Input.OrderNumber" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Tạo</button>
</form>
