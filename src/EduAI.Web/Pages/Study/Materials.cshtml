@page
@model EduAI.Web.Pages.Study.MaterialsModel
@{ ViewData["Title"] = "Tài liệu học tập"; }

<div class="page-header">
    <div>
        <h1 class="page-title">@Model.ViewModel.SubjectName</h1>
        <p class="page-subtitle">Tải tài liệu do giáo viên upload cho môn này.</p>
    </div>
    <a asp-page="/Subjects/Index" class="btn btn-outline-secondary">← Môn học</a>
</div>

@if (Model.ViewModel.Documents.Count == 0)
{
    <div class="alert alert-secondary">Chưa có tài liệu để tải.</div>
}
else
{
    @if (Model.ViewModel.Documents.Any(d => d.IndexStatus != "Indexed"))
    {
        <div class="alert alert-info">
            Một số tài liệu đang được xử lý. Bạn vẫn có thể tải về ngay, nhưng tính năng <strong>Hỏi đáp AI</strong> sẽ sẵn sàng sau khi xử lý hoàn tất.
        </div>
    }

    @if (Model.Chapters.Count == 0)
    {
        <div class="panel-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Phân loại</th>
                            <th>Giảng viên</th>
                            <th>Loại</th>
                            <th>Dung lượng</th>
                            <th>Ngày upload</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var doc in Model.ViewModel.Documents.OrderBy(d => d.FileName))
                    {
                        <tr>
                            <td><strong>@doc.FileName</strong></td>
                            <td><span class="badge bg-light text-dark border">@doc.CategoryLabel</span></td>
                            <td class="text-muted">@(string.IsNullOrWhiteSpace(doc.UploadedByName) ? "—" : doc.UploadedByName)</td>
                            <td><span class="badge badge-doc">@doc.FileType</span></td>
                            <td class="text-muted">@FormatFileSize(doc.FileSizeBytes)</td>
                            <td class="text-muted">@doc.CreatedAt.ToString("g")</td>
                            <td>
                                <a asp-page="/Study/Download" asp-route-id="@doc.Id" class="btn btn-sm btn-primary">Download</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        var orderedChapters = Model.Chapters.OrderBy(c => c.OrderNumber).ThenBy(c => c.Id).ToList();
        <div class="panel-card">
            <div class="panel-card-header">
                <strong>Nội dung khóa học</strong>
                <span class="text-muted ms-2">(@orderedChapters.Count chương · @Model.ViewModel.Documents.Count tài liệu)</span>
            </div>
            <div class="panel-card-body">
                <div class="accordion lms-accordion" id="materialsAccordion">
                    @for (var i = 0; i < orderedChapters.Count; i++)
                    {
                        var c = orderedChapters[i];
                        var chapterLessons = Model.Lessons
                            .Where(l => l.ChapterId == c.Id)
                            .OrderBy(l => l.OrderNumber).ThenBy(l => l.Id)
                            .ToList();
                        var collapseId = $"materials-chapter-{c.Id}";
                        var headingId = $"materials-heading-{c.Id}";
                        var chapterDocs = Model.ViewModel.Documents.Where(d => d.ChapterId == c.Id).ToList();
                        var isSingleLesson = chapterLessons.Count == 1;
                        var soleLesson = isSingleLesson ? chapterLessons[0] : null;

                        <div class="accordion-item">
                            <h2 class="accordion-header" id="@headingId">
                                <button class="accordion-button @(i > 0 ? "collapsed" : "")" type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId"
                                        aria-expanded="@(i == 0 ? "true" : "false")"
                                        aria-controls="@collapseId">
                                    <span class="lms-chapter-title">
                                        <span class="lms-chapter-num">@c.OrderNumber</span>
                                        <span class="fw-semibold">@c.Name</span>
                                    </span>
                                    <span class="lms-chapter-meta">@chapterDocs.Count tài liệu</span>
                                </button>
                            </h2>
                            <div id="@collapseId" class="accordion-collapse collapse @(i == 0 ? "show" : "")" aria-labelledby="@headingId" data-bs-parent="#materialsAccordion">
                                <div class="accordion-body lms-accordion-body">
                                    @if (chapterDocs.Count == 0)
                                    {
                                        <p class="text-muted small mb-0">Chưa có tài liệu trong chương này.</p>
                                    }
                                    else if (isSingleLesson && soleLesson != null)
                                    {
                                        var soleLessonDocs = chapterDocs
                                            .Where(d => d.LessonId == soleLesson.Id)
                                            .OrderBy(d => d.FileName)
                                            .ToList();
                                        <ul class="lms-doc-list lms-doc-list-flat list-unstyled mb-0">
                                            @foreach (var doc in soleLessonDocs)
                                            {
                                                <li class="lms-doc-row">
                                                    <span class="drive-icon drive-icon-sm">@GetFileIcon(doc.FileName)</span>
                                                    <div class="lms-doc-info">
                                                        <span class="lms-doc-name">@doc.FileName</span>
                                                        <span class="lms-doc-meta">@doc.CategoryLabel · @FormatFileSize(doc.FileSizeBytes) · @doc.CreatedAt.ToString("g")</span>
                                                    </div>
                                                    <a asp-page="/Study/Download" asp-route-id="@doc.Id" class="btn btn-sm btn-primary">Download</a>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <ul class="lms-lesson-list list-unstyled mb-0">
                                            @foreach (var l in chapterLessons)
                                            {
                                                var lessonDocs = chapterDocs
                                                    .Where(d => d.LessonId == l.Id)
                                                    .OrderBy(d => d.FileName)
                                                    .ToList();
                                                <li class="lms-lesson-block">
                                                    <div class="lms-lesson-row">
                                                        <div class="lms-lesson-main">
                                                            <span class="lms-lesson-title">@l.Name</span>
                                                            <span class="lms-lesson-meta">@lessonDocs.Count tài liệu</span>
                                                        </div>
                                                    </div>
                                                    @if (lessonDocs.Count > 0)
                                                    {
                                                        <ul class="lms-doc-list list-unstyled">
                                                            @foreach (var doc in lessonDocs)
                                                            {
                                                                <li class="lms-doc-row">
                                                                    <span class="drive-icon drive-icon-sm">@GetFileIcon(doc.FileName)</span>
                                                                    <div class="lms-doc-info">
                                                                        <span class="lms-doc-name">@doc.FileName</span>
                                                                        <span class="lms-doc-meta">@doc.CategoryLabel · @FormatFileSize(doc.FileSizeBytes) · @doc.CreatedAt.ToString("g")</span>
                                                                    </div>
                                                                    <a asp-page="/Study/Download" asp-route-id="@doc.Id" class="btn btn-sm btn-primary">Download</a>
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

@functions {
    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes / (1024.0 * 1024.0):0.#} MB";
    }

    private static string GetFileIcon(string? fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName ?? string.Empty).ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "PDF",
            ".doc" or ".docx" => "DOC",
            ".ppt" or ".pptx" => "PPT",
            ".xls" or ".xlsx" => "XLS",
            ".txt" => "TXT",
            _ => "FILE"
        };
    }
}
