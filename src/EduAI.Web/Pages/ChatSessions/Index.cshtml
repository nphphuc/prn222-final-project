@page
@model EduAI.Web.Pages.ChatSessions.IndexModel
@{ ViewData["Title"] = "Phiên chat"; ViewData["RealtimeEntities"] = "ChatSession,ChatMessage"; if (Model.SessionId.HasValue) { ViewData["RealtimeSessionId"] = Model.SessionId.Value.ToString(); } }

<div class="page-header mb-4">
    <div>
        <h1 class="page-title">Phiên chat</h1>
        <p class="page-subtitle">Quản trị viên xem phiên chat và tin nhắn — chỉ đọc, không chỉnh sửa.</p>
    </div>
</div>

<div class="row g-3 chat-admin-layout">
    <div class="col-lg-5">
        <div class="panel-card h-100">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <span>Phiên chat (@Model.ViewModel.Sessions.Count)</span>
                @if (Model.SessionId.HasValue)
                {
                    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">Xem tất cả</a>
                }
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Tiêu đề</th>
                            <th>Môn</th>
                            <th>SV</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.ViewModel.Sessions.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-muted text-center py-4">Chưa có phiên chat.</td>
                        </tr>
                    }
                    @foreach (var s in Model.ViewModel.Sessions)
                    {
                        var isActive = Model.SessionId == s.Id;
                        <tr class="@(isActive ? "table-active" : "")" style="cursor:pointer" onclick="window.location='@Url.Page("Index", new { sessionId = s.Id })'">
                            <td>@s.Id</td>
                            <td><strong>@s.Title</strong></td>
                            <td>@s.SubjectName</td>
                            <td class="text-muted small">@(s.StudentName ?? s.StudentId)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="panel-card h-100">
            <div class="panel-card-header">
                @if (Model.SelectedSession != null)
                {
                    <span>Tin nhắn — @Model.SelectedSession.Title <span class="text-muted">(#@Model.SelectedSession.Id)</span></span>
                }
                else
                {
                    <span>Tin nhắn</span>
                }
            </div>
            @if (!Model.SessionId.HasValue)
            {
                <div class="panel-card-body text-muted text-center py-5">
                    Chọn một phiên chat bên trái để xem tin nhắn.
                </div>
            }
            else if (Model.SelectedSession == null)
            {
                <div class="panel-card-body">
                    <div class="alert alert-warning mb-0">Không tìm thấy phiên chat #@Model.SessionId.</div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Role</th>
                                <th>Nội dung</th>
                                <th>Thời gian</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.Messages.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-muted text-center py-4">Phiên này chưa có tin nhắn.</td>
                            </tr>
                        }
                        @foreach (var m in Model.Messages)
                        {
                            <tr>
                                <td>@m.Id</td>
                                <td><span class="badge @(m.Role == "user" ? "bg-primary" : "bg-secondary")">@m.Role</span></td>
                                <td>@(m.Content.Length > 60 ? m.Content[..60] + "..." : m.Content)</td>
                                <td class="text-muted small text-nowrap">@m.CreatedAt.ToString("g")</td>
                                <td>
                                    <a asp-page="/ChatMessages/Details" asp-route-id="@m.Id" asp-route-sessionId="@Model.SessionId" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
