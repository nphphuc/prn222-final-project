@page "{id:int}"
@model EduAI.Web.Pages.Documents.EditModel
@{ ViewData["Title"] = "Sửa tài liệu"; }

<h2>Sửa tài liệu</h2>
<p class="text-muted">Môn: <strong>@Model.Input.SubjectName</strong></p>

<form method="post" enctype="multipart/form-data" class="card p-3">
    <input type="hidden" asp-for="Input.Id" />
    <input type="hidden" asp-for="Input.SubjectId" />
    <input type="hidden" asp-for="Input.SubjectName" />
    <input type="hidden" asp-for="Input.ChapterId" />
    <div asp-validation-summary="All" class="text-danger mb-2"></div>
    <div class="mb-3">
        <label asp-for="Input.FileName" class="form-label"></label>
        <input asp-for="Input.FileName" class="form-control" required />
    </div>
    <div class="mb-3">
        <label asp-for="Input.LessonId" class="form-label">Bài (Chương / Bài)</label>
        <select asp-for="Input.LessonId" asp-items="Model.LessonOptions" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Category" class="form-label">Loại tài liệu</label>
        <select asp-for="Input.Category" asp-items="Model.CategoryOptions" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label for="ReplacementFile" class="form-label">Thay file (tùy chọn)</label>
        <input type="file" name="ReplacementFile" id="ReplacementFile" class="form-control"
               accept=".pdf,.docx,.pptx,.txt" />
        <div class="form-text">
            Để trống nếu chỉ đổi tên/chương. Nếu chọn file mới, hệ thống sẽ thay file cũ và xử lý lại (re-index) nội dung.
        </div>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-secondary">Hủy</a>
    </div>
</form>
